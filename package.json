{
  "name": "rimelight-components",
  "version": "1.0.0",
  "private": true,
  "description": "A component library by Rimelight Entertainment.",
  "keywords": [
    "nuxt",
    "rimelight",
    "typescript",
    "vue"
  ],
  "homepage": "https://rimelight.com/tools/rimelight-components",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rimelight-Entertainment/rimelight-components.git"
  },
  "type": "module",
  "main": "./nuxt.config.ts",
  "exports": {
    ".": "./nuxt.config.ts",
    "./composables": "./app/composables/index.ts",
    "./types": "./app/types/index.ts",
    "./utils": "./app/utils/index.ts",
    "./auth": "./shared/auth/index.ts",
    "./auth/*": "./shared/auth/*",
    "./db": "./shared/db/index.ts",
    "./components/*": "./app/components/*"
  },
  "scripts": {
    "analyze": "nuxi analyze",
    "build": "nuxt build playground",
    "dev": "pnpm dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt prepare playground",
    "prepack": "nuxt prepare playground",
    "i18n": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types,playground}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\"",
    "i18n:add": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types,playground}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\" --add",
    "i18n:remove": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types,playground}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\" --remove",
    "i18n:fix": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types,playground}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\" --add --remove"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.98",
    "@nuxt/content": "^3.12.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^0.13.2",
    "@nuxt/ui": "^4.5.1",
    "@nuxtjs/device": "^4.0.0",
    "@nuxtjs/i18n": "^10.2.3",
    "@nuxtjs/seo": "^3.4.0",
    "@pinia/colada-devtools": "^0.3.0",
    "@pinia/colada-nuxt": "0.3.1",
    "@pinia/nuxt": "0.11.3",
    "@vueuse/nuxt": "^14.2.1",
    "better-auth": "^1.5.5",
    "better-sqlite3": "^12.8.0",
    "chroma-js": "^3.2.0",
    "date-fns": "^4.1.0",
    "defu": "^6.1.4",
    "motion-v": "^2.0.1",
    "nuxt": "^4.4.2",
    "nuxt-llms": "^0.2.0",
    "nuxt-og-image": "^5.1.13",
    "nuxt-security": "^2.5.1",
    "nuxt-studio": "^1.4.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.1",
    "uuid": "^13.0.0",
    "vite-plus": "^0.1.12",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/devtools": "^3.2.3",
    "@nuxt/hints": "^1.0.0",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/test-utils": "^4.0.0",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@types/chroma-js": "^3.1.2",
    "@types/node": "^25.5.0",
    "@types/youtube": "^0.1.2",
    "@vueuse/core": "^14.2.1",
    "drizzle-kit": "^0.31.9",
    "rimelight-cli": "github:Rimelight-Entertainment/rimelight-cli",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "vue-i18n-extract": "^2.0.7",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.74.0"
  },
  "peerDependencies": {
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.5.0",
    "@nuxtjs/i18n": "^10.2.3",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "nuxt": "^4.3.1",
    "vue": "^3.5.29",
    "zod": "^4.3.6"
  },
  "packageManager": "pnpm@10.32.1"
}