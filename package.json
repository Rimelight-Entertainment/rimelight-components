{
  "name": "rimelight-components",
  "version": "1.0.0",
  "private": true,
  "description": "A utility Nuxt layer by Rimelight Entertainment.",
  "keywords": [
    "nuxt",
    "rimelight",
    "typescript",
    "vue"
  ],
  "homepage": "https://rimelight.com/tools/rimelight-components",
  "license": "MIT",
  "author": {
    "name": "Daniel Marchi",
    "email": "danielmarchi@danielmarchi.dev",
    "url": "https://danielmarchi.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rimelight-Entertainment/rimelight-components.git"
  },
  "type": "module",
  "exports": {
    ".": "./nuxt.config.ts",
    "./composables": "./app/composables/index.ts",
    "./types": "./app/types/index.ts",
    "./utils": "./app/utils/index.ts",
    "./auth": "./shared/auth/index.ts",
    "./auth/*": "./shared/auth/*",
    "./db": "./shared/db/index.ts",
    "./components/*": "./app/components/*"
  },
  "scripts": {
    "analyze": "nuxi analyze",
    "build": "nuxt build --profile=verbose playground",
    "dev": "pnpm dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt prepare playground",
    "prepack": "nuxt prepare playground",
    "i18n": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types,playground}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\"",
    "i18n:add": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types,playground}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\" --add",
    "i18n:remove": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types,playground}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\" --remove",
    "i18n:fix": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types,playground}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\" --add --remove"
  },
