{
  "name": "rimelight-components",
  "version": "1.0.0",
  "private": true,
  "description": "A utility Nuxt layer by Rimelight Entertainment.",
  "keywords": [
    "nuxt",
    "rimelight",
    "typescript",
    "vue"
  ],
  "homepage": "https://rimelight.com/tools/rimelight-components",
  "license": "MIT",
  "author": {
    "name": "Daniel Marchi",
    "email": "danielmarchi@danielmarchi.dev",
    "url": "https://danielmarchi.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rimelight-Entertainment/rimelight-components.git"
  },
  "type": "module",
  "exports": {
    ".": "./nuxt.config.ts",
    "./composables": "./app/composables/index.ts",
    "./types": "./app/types/index.ts",
    "./utils": "./app/utils/index.ts",
    "./auth": "./shared/auth/index.ts",
    "./auth/*": "./shared/auth/*",
    "./db": "./shared/db/index.ts",
    "./validators/*": "./shared/validators/*",
    "./components/*": "./app/components/*"
  },
  "scripts": {
    "postinstall": "nuxt prepare && nuxt prepare playground",
    "prepare": "vp config",
    "dev": "nuxt dev playground",
    "build": "nuxt build playground",
    "generate": "nuxt generate playground",
    "preview": "nuxt preview playground",
    "analyze": "nuxt analyze playground",
    "i18n": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\"",
    "i18n:add": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\" --add",
    "i18n:remove": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\" --remove",
    "i18n:fix": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\" --add --remove",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.98",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/simple-icons": "^1.2.74",
    "@lunariajs/core": "^0.1.1",
    "@neondatabase/serverless": "^1.0.2",
    "@nuxt/content": "^3.12.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^0.13.2",
    "@nuxt/ui": "^4.5.1",
    "@nuxtjs/device": "^4.0.0",
    "@nuxtjs/html-validator": "2.1.0",
    "@nuxtjs/i18n": "^10.2.3",
    "@nuxtjs/robots": "^5.7.1",
    "@nuxtjs/sitemap": "^7.6.0",
    "@pinia/colada-devtools": "^0.3.0",
    "@pinia/colada-nuxt": "0.3.1",
    "@pinia/nuxt": "0.11.3",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@vueuse/core": "14.2.1",
    "@vueuse/nuxt": "14.2.1",
    "better-auth": "^1.5.5",
    "better-sqlite3": "^12.8.0",
    "chroma-js": "^3.2.0",
    "date-fns": "^4.1.0",
    "defu": "^6.1.4",
    "drizzle-orm": "^0.45.1",
    "motion-v": "^2.0.1",
    "nuxt": "^4.4.2",
    "nuxt-llms": "^0.2.0",
    "nuxt-og-image": "^6.0.3",
    "nuxt-security": "^2.5.1",
    "nuxt-studio": "^1.4.0",
    "perfect-debounce": "2.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "uuid": "^13.0.0",
    "valibot": "1.2.0",
    "vue": "^3.5.30",
    "vue-data-ui": "3.15.12",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/hints": "^1.0.0",
    "@nuxt/test-utils": "4.0.0",
    "@takumi-rs/wasm": "^0.73.1",
    "@types/chroma-js": "^3.1.2",
    "@types/node": "^25.5.0",
    "@types/youtube": "^0.1.2",
    "@valibot/to-json-schema": "^1.5.0",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "drizzle-kit": "^0.31.10",
    "knip": "^5.87.0",
    "vite-plus": "latest",
    "vue-i18n-extract": "^2.0.7",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.75.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "esbuild",
      "sharp",
      "vue-demi",
      "workerd"
    ]
  }
}
